ishikopath = envvar("ISHIKO_CPP_ROOT");
import $(ishikopath)/test-framework/include/Ishiko/TestFramework.bkl;

toolsets = gnu vs2022 vs2019 vs2017;

gnu.makefile = ../gnumake/GNUmakefile;
vs2022.solutionfile = ../vc17/nuime_lib_tests.sln;
vs2019.solutionfile = ../vc16/nuime_lib_tests.sln;
vs2017.solutionfile = ../vc15/nuime_lib_tests.sln;

program nuime_lib_tests : IshikoTestFramework
{
    if ($(toolset) == gnu)
    {
        cxx-compiler-options = "-std=c++11";
        libs += IshikoTestFramework IshikoTestFrameworkCore IshikoConfiguration IshikoDiff IshikoXML IshikoFileSystem IshikoIO IshikoProcess IshikoTime IshikoText IshikoErrors IshikoBasePlatform;
        libs += fmt boost_filesystem;
    }

    if ($(toolset) != gnu)
    {
        archs = x86 x86_64;
        cxx-compiler-options = "/utf-8";
    }

    sources
    {
        ../../src/main.cpp
    }
}
